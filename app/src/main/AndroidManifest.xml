<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
      Media/contacts read access for the hide/import pipeline. On API 33+ the granular
      READ_MEDIA_* permissions apply; on API 32 and below READ_EXTERNAL_STORAGE covers
      photos/videos/audio/files. Media originals are removed via MediaStore delete
      requests (user-consented on API 30+). Contacts are not MediaStore items and have
      no system delete-consent dialog, so hiding a contact deletes its source row via
      ContactsContract, which requires WRITE_CONTACTS (the runtime grant is the consent).
    -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <!--
      Un-hide (restore-to-gallery) write-back to public storage on legacy devices (API ≤28):
      restoring a hidden file writes a real file under the public external dir, which needs
      WRITE_EXTERNAL_STORAGE. On API 29+ the MediaStore insert publishes with no storage
      permission, so this is capped at 28.
    -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.WRITE_CONTACTS" />

    <!--
      All Files Access — the vault-technique directive (§1–2, APP-142): encrypted blobs
      live in a hidden PUBLIC .CalcVault/ dot-folder on shared storage so hidden data
      SURVIVES app uninstall. Writing a top-level dot-folder on shared storage needs
      MANAGE_EXTERNAL_STORAGE on API 30+ (granted via the point-of-need primer, flow-logic
      §4). API 29 and below use legacy external storage (WRITE_EXTERNAL_STORAGE +
      requestLegacyExternalStorage on the application below).
    -->
    <uses-permission
        android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />

    <application
        android:name=".CalculatorVaultApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:requestLegacyExternalStorage="true"
        android:supportsRtl="true"
        android:theme="@style/Theme.CalculatorVault">

        <!--
          Single launcher entry point = the calculator disguise. The vault is
          reached only via the secret code detected inside the calculator; it is
          intentionally NOT a separately launchable component.
        -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.CalculatorVault">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
