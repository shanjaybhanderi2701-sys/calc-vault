<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
      Media read access for the hide/import pipeline. All Files Access
      (MANAGE_EXTERNAL_STORAGE, declared below) is the SOLE mandatory vault permission: on
      API 30+ it already grants full read/write to every shared media category
      (photos/videos/audio/files), so the granular READ_MEDIA_* runtime permissions are
      redundant and off-parity with the reference app xlock — they are intentionally NOT
      declared (board directive APP-219 / APP-203). Only the legacy READ_EXTERNAL_STORAGE
      fallback (API ≤32) remains for pre-scoped-storage devices that lack All Files Access.
      Media originals are removed via MediaStore delete requests (user-consented on API 30+).
      Contacts permissions are also intentionally NOT declared (APP-207 scope refinement).
    -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!--
      All Files Access — the vault-technique directive (§1–2, APP-142): encrypted blobs
      live in a hidden PUBLIC .CalcVault/ dot-folder on shared storage so hidden data
      SURVIVES app uninstall. Writing a top-level dot-folder on shared storage needs
      MANAGE_EXTERNAL_STORAGE on API 30+ (granted via the point-of-need primer, flow-logic
      §4). API 29 and below use legacy external storage (the single WRITE_EXTERNAL_STORAGE
      declared above, capped at 29 + requestLegacyExternalStorage on the application below).
      That same legacy write also backs the un-hide restore-to-gallery path (APP-170).
    -->
    <uses-permission
        android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />

    <!--
      Phase-1 scope guard (APP-227): App Lock / Intruder Selfie / Explore permissions
      (PACKAGE_USAGE_STATS, CAMERA, SYSTEM_ALERT_WINDOW, QUERY_ALL_PACKAGES, INTERNET) and
      their manifest components are intentionally NOT declared — those features ship in
      Phase 3/4 and re-add their own entries. Phase 1 is fully offline with the storage,
      foreground-service and notification permissions below only.
    -->

    <!--
      Bulk hide/restore hardening (build spec §11, APP-225): batch encrypt/restore runs
      under a dataSync foreground service (BulkOpService) with a "Processing N of M"
      notification so the OS does not kill a half-finished batch. POST_NOTIFICATIONS is
      never gated on — if denied on API 33+ the operation still runs, just without the
      visible progress notification.
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".CalculatorVaultApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:requestLegacyExternalStorage="true"
        android:supportsRtl="true"
        android:theme="@style/Theme.CalculatorVault">

        <!--
          The calculator disguise activity. It is NOT itself a launcher (exported=false):
          the two activity-aliases below are the launcher entry points so Settings →
          Disguise can swap the visible icon/name at runtime by enabling exactly one. The
          vault is reached only via the secret code typed inside the calculator.
        -->
        <!--
          NOT excluded from recents by default (spec §10, APP-225): a calculator that
          vanishes from the app switcher is more suspicious than one whose preview is
          blanked. FLAG_SECURE (set in code) blanks the recents thumbnail; fully hiding the
          task is an opt-in Settings toggle applied at runtime via setExcludeFromRecents.
        -->
        <!--
          APP-381 #1 — handle rotation / size configuration changes in-process instead of
          recreating the activity. This single-activity host is 100% Jetpack Compose, which
          re-lays-out reactively on a configuration change, so keeping the activity alive means
          the immersive video player's ExoPlayer keeps playing seamlessly across a device
          rotation (no restart-from-zero, no re-decrypt of the encrypted stream). A forced
          recreate / process-death restore is still covered by RetainedPlaybackEffect
          (rememberSaveable playhead + play/pause).
        -->
        <activity
            android:name=".MainActivity"
            android:configChanges="orientation|screenSize|smallestScreenSize|screenLayout|keyboardHidden|density|uiMode"
            android:exported="false"
            android:theme="@style/Theme.CalculatorVault" />

        <!-- Default disguise: "Calculator" tile. Enabled at install. -->
        <activity-alias
            android:name=".CalculatorDefaultAlias"
            android:targetActivity=".MainActivity"
            android:enabled="true"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- Alternate disguise: plain "Calc" tile. Disabled until chosen in Settings. -->
        <activity-alias
            android:name=".CalculatorAltAlias"
            android:targetActivity=".MainActivity"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_alt"
            android:label="@string/app_name_alt">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!--
          Phase-1 scope guard (APP-227): the App Lock components (LockScreenActivity,
          AppLockAccessibilityService), the Prevent-uninstall VaultDeviceAdminReceiver and
          the Explore browser are NOT registered here. Their Kotlin sources stay in-tree
          (dormant, unreachable — no nav route or Settings row starts them) and Phase 3/4
          restore the manifest entries when those features ship.
        -->

        <!--
          Share temp-copy provider (APP-294, security contract): serves ONLY the
          cacheDir/share/ session tree (see @xml/vault_share_paths) as opaque read-only
          content:// URIs to the system share sheet. Not exported — receivers reach it
          exclusively through per-URI grants attached to the share intent, and the temp
          copies themselves are purged the moment the share flow returns (VaultShare).
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.share"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/vault_share_paths" />
        </provider>

        <!--
          Foreground service that keeps bulk hide/restore alive with a progress
          notification (build spec §11). Started by the vault repository around each
          batch; observes BulkOpProgress and stops itself when the batch completes.
        -->
        <service
            android:name=".vault.media.BulkOpService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />
    </application>

</manifest>
