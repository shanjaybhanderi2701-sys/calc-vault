<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
      Media/contacts read access for the hide/import pipeline. On API 33+ the granular
      READ_MEDIA_* permissions apply; on API 32 and below READ_EXTERNAL_STORAGE covers
      photos/videos/audio/files. Media originals are removed via MediaStore delete
      requests (user-consented on API 30+). Contacts are not MediaStore items and have
      no system delete-consent dialog, so hiding a contact deletes its source row via
      ContactsContract, which requires WRITE_CONTACTS (the runtime grant is the consent).
    -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.WRITE_CONTACTS" />

    <!--
      AppLock enforcement + Intruder Selfie (Phase 3, APP-160).
      - PACKAGE_USAGE_STATS: read the foreground package (Usage Access, user-granted in Settings).
      - CAMERA: front-camera intruder capture, requested only when Intruder Selfie is enabled.
      - SYSTEM_ALERT_WINDOW: draw the lock screen over other apps on older devices.
      The accessibility service (declared below) is the primary real-time trigger.
      QUERY_ALL_PACKAGES is needed to list launchable apps for the AppLock picker on API 30+.
    -->
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.front" android:required="false" />

    <application
        android:name=".CalculatorVaultApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.CalculatorVault">

        <!--
          Single launcher entry point = the calculator disguise. The vault is
          reached only via the secret code detected inside the calculator; it is
          intentionally NOT a separately launchable component.
        -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.CalculatorVault">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
          The AppLock challenge, raised over a locked app by the accessibility service.
          Not exported (only our service starts it), excluded from Recents, and singleTask so
          re-triggering reuses one instance instead of stacking lock screens.
        -->
        <activity
            android:name=".applock.LockScreenActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:launchMode="singleTask"
            android:taskAffinity=""
            android:theme="@style/Theme.CalculatorVault" />

        <!--
          Real-time enforcement: observes foreground-app changes and raises the lock screen
          when a locked app comes forward. BIND_ACCESSIBILITY_SERVICE restricts binding to
          the system; the user must enable it in Accessibility settings (primer flow).
        -->
        <service
            android:name=".applock.AppLockAccessibilityService"
            android:exported="false"
            android:label="@string/applock_service_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/applock_accessibility_config" />
        </service>
    </application>

</manifest>
