<?xml version="1.0" encoding="utf-8"?>
<!--
  Vault is privacy-sensitive: exclude app data from cloud backup and device
  transfer by default. Revisit selectively if an explicit export feature lands.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
    </device-transfer>
</data-extraction-rules>
